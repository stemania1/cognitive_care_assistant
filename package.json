{
  "name": "cognitive_care_assistant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"NEXT,THERMAL,EMG\" --prefix-colors \"blue,green,yellow\" \"next dev --turbopack -p 3000\" \"node bridges/usb-serial-thermal-receiver.js\" \"python -u bridges/usb-serial-emg-receiver.py\"",
    "dev:thermal-usb": "concurrently --names \"NEXT,THERMAL_USB\" --prefix-colors \"blue,green\" \"next dev --turbopack -p 3000\" \"node bridges/usb-serial-thermal-receiver.js\"",
    "thermal:usb": "node bridges/usb-serial-thermal-receiver.js",
    "thermal:usb:test": "node scripts/test-usb-serial-thermal.js",
    "thermal:list-ports": "node -e \"require('serialport').SerialPort.list().then(p=>console.log(JSON.stringify(p.map(x=>({path:x.path,manufacturer:x.manufacturer})),null,2)))\"",
    "dev:next": "next dev --turbopack -p 3000",
    "dev:unlock": "node -e \"const fs=require('fs');const p='.next/dev/lock';try{fs.unlinkSync(p);console.log('Removed',p);}catch(e){if(e.code!=='ENOENT')throw e;}\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "emg-server": "node bridges/emg-server.js",
    "emg:usb": "python bridges/usb-serial-emg-receiver.py",
    "emg:usb:node": "node bridges/usb-serial-emg-receiver.js",
    "dev:emg-usb": "concurrently --names \"NEXT,EMG_USB\" --prefix-colors \"blue,yellow\" \"next dev --turbopack -p 3000\" \"node bridges/usb-serial-emg-receiver.js\"",
    "dev:all": "concurrently \"npm run dev\" \"npm run emg-server\"",
    "dev:all-usb": "concurrently --names \"NEXT,THERMAL_USB,EMG_USB\" --prefix-colors \"blue,green,yellow\" \"next dev --turbopack -p 3000\" \"node bridges/usb-serial-thermal-receiver.js\" \"node bridges/usb-serial-emg-receiver.js\"",
    "start:emg": "concurrently --names \"NEXT,EMG,BT\" --prefix-colors \"blue,yellow,green\" \"npm run dev\" \"npm run emg-server\" \"node bridges/bluetooth-receiver.js\"",
    "start:thermal": "concurrently --names \"NEXT,THERMAL\" --prefix-colors \"blue,green\" \"npm run dev\" \"node bridges/bluetooth-thermal-receiver.js\"",
    "sensor:setup": "python scripts/sensor-setup.py",
    "code-pdf": "node scripts/generate-code-pdf.js",
    "copyright-deposit": "node scripts/generate-copyright-deposit.js"
  },
  "dependencies": {
    "@clerk/localizations": "^4.4.0",
    "@clerk/nextjs": "^6.36.7",
    "@hcaptcha/react-hcaptcha": "^1.14.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@serialport/parser-readline": "^13.0.0",
    "@supabase/supabase-js": "^2.58.0",
    "chart.js": "^4.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "framer-motion": "^12.38.0",
    "next": "^16.1.1",
    "node-fetch": "^3.3.2",
    "react": "^19.2.3",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.2.3",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "concurrently": "^9.2.1",
    "pdfkit": "^0.17.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
